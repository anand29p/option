# Options Trading Bot — Environment Configuration TEMPLATE
# ─────────────────────────────────────────────────────────────────
# Copy this file: cp .env.example .env
# Then fill in your credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Trading mode: 'paper' (safe, no real orders) | 'live' (real money!)
MODE=paper

# Paper capital and per-trade budget
PAPER_CAPITAL=100000
MAX_CAPITAL_PER_TRADE=10000

# Active execution allowlist.
# Only these INDEX:StrategyName or STOCK:StrategyName pairs can place paper trades.
# Other valid signals are logged to logs/shadow_signals.csv.
# Examples:
#   BANKNIFTY:RSIDivergence     (index option)
#   TCS:RSIDivergence           (stock option)
#   HDFC BANK:VWAPReversion     (stock option)
ACTIVE_STRATEGY_ALLOWLIST=BANKNIFTY:RSIDivergence,BANKNIFTY:VWAPReversion,BANKNIFTY:ORBBreakout,BANKNIFTY:MeanReversion
SHADOW_SIGNAL_LOG=true
SHADOW_LOG_FILE=logs/shadow_signals.csv
SIGNAL_CONSENSUS_ENABLED=true
MIN_SIGNAL_CONSENSUS=2
FALLBACK_VIX=15.0
RUNTIME_STATUS_FILE=logs/runtime_status.json

# Optional: start legacy Flask dashboard at http://127.0.0.1:5000
# Default is false (Streamlit dashboard is launched via: python main.py --dashboard)
ENABLE_FLASK_DASHBOARD=false

# ── Dhan API Credentials (FREE) ───────────────────────────────────
# Step 1: Sign up at https://dhan.co (free demat + trading account)
# Step 2: Go to https://dhanhq.co/docs/v2/ → Generate Access Token
# Step 3: Paste your credentials below
DHAN_CLIENT_ID=your_client_id_here
DHAN_ACCESS_TOKEN=your_access_token_here

# ── Optional: Alpha Vantage (News Sentiment upgrade) ──────────────
# Free tier: 25 requests/day. Get key at https://www.alphavantage.co/
# Leave blank to use free RSS sentiment (default, no key needed)
ALPHA_VANTAGE_KEY=
